# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000

# ── Client (prefix with VITE_ so Vite exposes them) ───────────────────────────
# URL of the backend server (leave empty to use Vite proxy on localhost)
VITE_SERVER_URL=http://localhost:4000

# Set to "true" to show the "Simulate Cry" demo button in production builds
VITE_DEMO_MODE=true
